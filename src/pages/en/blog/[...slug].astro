---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const lang = 'en';
	const posts = (await getCollection('blog')).filter((post) => post.id.startsWith(`${lang}/`));
	return posts.map((post) => ({
		params: { slug: post.id.slice(lang.length + 1) },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);
const words = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.ceil(words / 200);
---

<BlogPost {...post.data} headings={headings} readingTime={readingTime}>
	<Content />
</BlogPost>
