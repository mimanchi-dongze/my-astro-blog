---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { useTranslatedPath } from '../../i18n/utils';

const lang = 'zh-cn';
const translatePath = useTranslatedPath(lang);
const posts = (await getCollection('blog'))
	.filter((post) => post.id.startsWith(`${lang}/`))
	.sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 3rem 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				display: flex;
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				grid-column: 1 / -1;
				margin-bottom: 1rem;
			}
			ul li:first-child a {
				display: flex;
				flex-direction: row;
				gap: 3rem;
				align-items: center;
			}
			ul li:first-child img {
				width: 55%;
				margin-bottom: 0;
				aspect-ratio: 2 / 1;
			}
			ul li:first-child .content {
				flex: 1;
			}
			ul li:first-child .title {
				font-size: 2.5rem;
				line-height: 1.2;
				margin-bottom: 0.75rem;
			}
			ul li:first-child .date {
				font-size: 1.1rem;
			}
			ul li img {
				width: 100%;
				margin-bottom: 1rem;
				border-radius: 16px;
				aspect-ratio: 2 / 1;
				object-fit: cover;
				transition: box-shadow 0.3s ease, transform 0.3s ease;
			}
			ul li a {
				display: flex;
				flex-direction: column;
				width: 100%;
			}
			.content {
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1.5rem;
				font-weight: 700;
				transition: color 0.2s ease;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			ul li a:hover .title {
				color: rgb(var(--accent));
			}
			ul li a:hover img {
				box-shadow: var(--box-shadow);
				transform: translateY(-4px);
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 0.5rem;
			}
			.tag {
				font-size: 0.8rem;
				padding: 0.2rem 0.6rem;
				background-color: rgb(var(--gray-light));
				color: rgb(var(--gray));
				border-radius: 999px;
				transition: background-color 0.2s ease, color 0.2s ease;
			}
			ul li a:hover .tag {
				background-color: rgb(var(--accent));
				color: white;
			}
			.filter-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 2rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.filter-btn {
				font-size: 0.9rem;
				padding: 0.4rem 1rem;
				background-color: transparent;
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray));
				border-radius: 999px;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.filter-btn:hover, .filter-btn.active {
				background-color: rgb(var(--accent));
				color: white;
				border-color: rgb(var(--accent));
			}
			@media (max-width: 720px) {
				ul {
					grid-template-columns: 1fr;
					gap: 2.5rem;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child a {
					flex-direction: column;
					gap: 1rem;
				}
				ul li:first-child img {
					width: 100%;
				}
				ul li:first-child .title {
					font-size: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="filter-bar" id="tag-filter">
					<button class="filter-btn active" data-tag="all">All</button>
					{tags.map(tag => (
						<button class="filter-btn" data-tag={tag}>{tag}</button>
					))}
				</div>
				<ul>
				{
					posts.map((post) => {
						const slug = post.id.slice(lang.length + 1);
						return (
							<li class="post-item" data-tags={(post.data.tags || []).join(',')}>
								<a href={translatePath(`/blog/${slug}/`)}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<div class="content">
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										{post.data.tags && post.data.tags.length > 0 && (
											<div class="tags">
												{post.data.tags.map((tag: string) => (
													<span class="tag" data-tag={tag}>{tag}</span>
												))}
											</div>
										)}
									</div>
								</a>
							</li>
						);
					})
				}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			function initTagFilter() {
				const filterBar = document.getElementById('tag-filter');
				if (!filterBar || filterBar.dataset.initialized) return;
				filterBar.dataset.initialized = 'true';

				const buttons = filterBar.querySelectorAll('.filter-btn');
				const posts = document.querySelectorAll('.post-item');
				const postTags = document.querySelectorAll('.post-item .tag');

				function filterByTag(selectedTag: string | undefined) {
					buttons.forEach(b => b.classList.remove('active'));
					const activeBtn = Array.from(buttons).find(b => (b as HTMLElement).dataset.tag === selectedTag);
					if (activeBtn) activeBtn.classList.add('active');

					posts.forEach(post => {
						const postEl = post as HTMLElement;
						if (!selectedTag || selectedTag === 'all') {
							postEl.style.display = '';
						} else {
							const tags = postEl.dataset.tags?.split(',') || [];
							if (tags.includes(selectedTag)) {
								postEl.style.display = '';
							} else {
								postEl.style.display = 'none';
							}
						}
					});
				}

				buttons.forEach(btn => {
					btn.addEventListener('click', () => {
						filterByTag((btn as HTMLElement).dataset.tag);
					});
				});

				postTags.forEach(tag => {
					tag.addEventListener('click', (e) => {
						e.preventDefault();
						filterByTag((tag as HTMLElement).dataset.tag);
						// Scroll to filter bar smoothly
						filterBar.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});
				});
			}

			document.addEventListener('astro:page-load', initTagFilter);
		</script>
	</body>
</html>
