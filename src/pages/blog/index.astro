---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { useTranslatedPath } from '../../i18n/utils';

const lang = 'zh-cn';
const translatePath = useTranslatedPath(lang);
const getPublishedTime = (publishedAt: string, pubDate: Date) => {
	const publishedAtTime = new Date(publishedAt).valueOf();
	return Number.isNaN(publishedAtTime) ? pubDate.valueOf() : publishedAtTime;
};
const posts = (await getCollection('blog'))
	.filter((post) => post.id.startsWith(`${lang}/`))
	.sort((a, b) => getPublishedTime(b.data.publishedAt, b.data.pubDate) - getPublishedTime(a.data.publishedAt, a.data.pubDate));

const tags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort();
---

<!doctype html>
<html lang="zh-cn">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1120px, 100%);
				padding: 0 1rem;
			}
			.page-head {
				margin-bottom: 1.2rem;
			}
			.page-head h1 {
				margin: 0;
				font-size: clamp(1.8rem, 4vw, 2.4rem);
			}
			.page-head p {
				margin: 0.45rem 0 0;
				color: rgb(var(--gray));
			}
			.blog-layout {
				display: grid;
				grid-template-columns: 260px minmax(0, 1fr);
				gap: 1.25rem;
				align-items: start;
			}
			.filters-panel {
				position: sticky;
				top: 5.5rem;
				border: 1px solid rgb(var(--gray-light));
				background: rgb(var(--gray-light) / 28%);
				border-radius: 14px;
				padding: 1rem;
			}
			.filters-panel h2 {
				margin: 0;
				font-size: 1rem;
			}
			.filters-panel p {
				margin: 0.45rem 0 0.9rem;
				color: rgb(var(--gray));
				font-size: 0.88rem;
			}
			.filter-bar {
				display: flex;
				flex-wrap: wrap;
				gap: 0.45rem;
				margin-bottom: 0.9rem;
				max-height: 220px;
				overflow: auto;
			}
			.filter-btn {
				font-size: 0.84rem;
				padding: 0.35rem 0.75rem;
				background: transparent;
				border: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray));
				border-radius: 999px;
				cursor: pointer;
				transition: all 0.2s ease;
			}
			.filter-btn:hover,
			.filter-btn.active {
				background-color: rgb(var(--accent));
				border-color: rgb(var(--accent));
				color: white;
			}
			.sort-wrap {
				display: block;
				font-size: 0.84rem;
				color: rgb(var(--gray));
			}
			.sort-wrap select {
				width: 100%;
				margin-top: 0.45rem;
				padding: 0.45rem 0.55rem;
				border-radius: 8px;
				border: 1px solid rgb(var(--gray-light));
				background: var(--bg);
				color: var(--text);
			}
			.posts-panel ul {
				display: grid;
				grid-template-columns: 1fr;
				gap: 1rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			.post-item {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				padding: 0.9rem;
				background: rgb(var(--gray-light) / 16%);
			}
			.post-link {
				display: grid;
				grid-template-columns: 220px minmax(0, 1fr);
				gap: 1rem;
				align-items: start;
				text-decoration: none;
			}
			.post-link img {
				width: 100%;
				border-radius: 16px;
				aspect-ratio: 2 / 1;
				object-fit: cover;
				transition: box-shadow 0.3s ease, transform 0.3s ease;
			}
			.post-link:hover .title {
				color: rgb(var(--accent));
			}
			.post-link:hover img {
				box-shadow: var(--box-shadow);
				transform: translateY(-3px);
			}
			.content {
				display: flex;
				flex-direction: column;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--black));
				line-height: 1.3;
				font-size: 1.5rem;
				font-weight: 700;
				transition: color 0.2s ease;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			.card-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 0.7rem;
			}
			.tag-chip {
				font-size: 0.8rem;
				padding: 0.2rem 0.6rem;
				background-color: rgb(var(--gray-light));
				color: rgb(var(--gray));
				border: 0;
				cursor: pointer;
				border-radius: 999px;
				transition: background-color 0.2s ease, color 0.2s ease;
			}
			.tag-chip:hover {
				background-color: rgb(var(--accent));
				color: white;
			}
			@media (max-width: 980px) {
				.blog-layout {
					grid-template-columns: 1fr;
				}
				.filters-panel {
					position: static;
				}
			}
			@media (max-width: 720px) {
				.post-link {
					grid-template-columns: 1fr;
				}
				.post-item {
					padding: 0.75rem;
				}
				.title {
					font-size: 1.2rem;
				}
				.page-head {
					margin-bottom: 1rem;
				}
			}
			@media (max-width: 448px) {
				.page-head h1 {
					font-size: 1.6rem;
				}
				.filter-btn {
					padding: 0.45rem 0.85rem;
					min-height: 40px;
				}
				.sort-wrap select {
					min-height: 44px;
				}
				.post-item {
					padding: 0.6rem;
					border-radius: 12px;
				}
				.post-link img {
					border-radius: 10px;
				}
				.title {
					font-size: 1.1rem;
				}
				.tag-chip {
					padding: 0.3rem 0.7rem;
					min-height: 36px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<h1>博客文章</h1>
				<p>按主题筛选你想看的内容，或者直接进入文章深入阅读。</p>
			</section>
			<section>
				<div class="blog-layout" data-blog-controls="zh-cn">
					<aside class="filters-panel">
						<h2>标签筛选</h2>
						<p>点击标签快速过滤文章。</p>
						<div class="filter-bar" id="tag-filter">
							<button class="filter-btn active" data-tag="all">All</button>
							{tags.map((tag) => (
								<button class="filter-btn" data-tag={tag}>{tag}</button>
							))}
						</div>
						<label class="sort-wrap">
							排序
							<select id="sort-select">
								<option value="newest">最新优先</option>
								<option value="oldest">最早优先</option>
							</select>
						</label>
					</aside>
					<div class="posts-panel">
						<ul id="post-list">
						{
							posts.map((post) => {
								const slug = post.id.slice(lang.length + 1);
								return (
									<li class="post-item" data-tags={(post.data.tags || []).join(',')} data-date={post.data.publishedAt || post.data.pubDate.toISOString()}>
										<a class="post-link" href={translatePath(`/blog/${slug}/`)}>
											{post.data.heroImage && (
												<Image width={720} height={360} src={post.data.heroImage} alt="" />
											)}
											<div class="content">
												<h4 class="title">{post.data.title}</h4>
												<p class="date">
													<FormattedDate date={post.data.publishedAt || post.data.pubDate} />
												</p>
											</div>
										</a>
										{post.data.tags && post.data.tags.length > 0 && (
											<div class="card-tags">
												{post.data.tags.map((tag: string) => (
													<button class="tag-chip" data-tag={tag}>{tag}</button>
												))}
											</div>
										)}
									</li>
								);
							})
						}
						</ul>
					</div>
				</div>
			</section>
		</main>
		<Footer />
		<script>
			function initTagFilter() {
				const page = document.querySelector('[data-blog-controls="zh-cn"]');
				if (!page || page.dataset.initialized) return;
				page.dataset.initialized = 'true';

				const filterBar = page.querySelector('#tag-filter');
				const sortSelect = page.querySelector('#sort-select');
				const postList = page.querySelector('#post-list');
				if (!filterBar || !sortSelect || !postList) return;

				const buttons = filterBar.querySelectorAll('.filter-btn');
				const posts = Array.from(postList.querySelectorAll('.post-item'));
				const postTags = postList.querySelectorAll('.tag-chip');
				let selectedTag = 'all';

				function applyControls() {
					buttons.forEach(b => b.classList.remove('active'));
					const activeBtn = Array.from(buttons).find(b => (b as HTMLElement).dataset.tag === selectedTag);
					if (activeBtn) activeBtn.classList.add('active');

					const order = (sortSelect as HTMLSelectElement).value;
					posts.sort((a, b) => {
						const ad = new Date((a as HTMLElement).dataset.date || '').getTime();
						const bd = new Date((b as HTMLElement).dataset.date || '').getTime();
						return order === 'oldest' ? ad - bd : bd - ad;
					});
					posts.forEach((post) => postList.appendChild(post));

					posts.forEach(post => {
						const postEl = post as HTMLElement;
						if (selectedTag === 'all') {
							postEl.style.display = '';
						} else {
							const tags = postEl.dataset.tags?.split(',') || [];
							postEl.style.display = tags.includes(selectedTag) ? '' : 'none';
						}
					});
				}

				buttons.forEach(btn => {
					btn.addEventListener('click', () => {
						selectedTag = (btn as HTMLElement).dataset.tag || 'all';
						applyControls();
					});
				});
				sortSelect.addEventListener('change', applyControls);

				postTags.forEach(tag => {
					tag.addEventListener('click', (e) => {
						e.stopPropagation();
						selectedTag = (tag as HTMLElement).dataset.tag || 'all';
						applyControls();
						filterBar.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});
				});

				applyControls();
			}

			document.addEventListener('astro:page-load', initTagFilter);
		</script>
	</body>
</html>
