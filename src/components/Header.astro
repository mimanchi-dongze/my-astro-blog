---
import { SITE_TITLE } from '../consts';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import HeaderLink from './HeaderLink.astro';
import LanguagePicker from './LanguagePicker.astro';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const homePath = translatePath('/');
const blogPath = translatePath('/blog/');
const aboutPath = translatePath('/about/');
const searchPath = translatePath('/search/');
---

<header>
	<nav>
		<h2><a href={homePath}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href={homePath}>{t('nav.home')}</HeaderLink>
			<HeaderLink href={blogPath}>{t('nav.blog')}</HeaderLink>
			<HeaderLink href={aboutPath}>{t('nav.about')}</HeaderLink>
			<HeaderLink href={searchPath}>{t('nav.search')}</HeaderLink>
		</div>
		<div class="header-actions">
			<LanguagePicker />
			<ThemeToggle />
			<div class="social-links">
				<a href="https://github.com/mimanchi-dongze" target="_blank">
				<span class="sr-only">Go to Dongze's GitHub profile</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
				</a>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.header-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	@media (max-width: 720px) {
		nav {
			flex-wrap: wrap;
			align-items: center;
			padding: 0.3rem 0;
		}
		h2 {
			order: 1;
		}
		.header-actions {
			order: 2;
			margin-left: auto;
		}
		.internal-links {
			order: 3;
			width: 100%;
			overflow-x: auto;
			white-space: nowrap;
			padding-bottom: 0.2rem;
		}
		nav a {
			padding: 0.75em 0.5em;
			flex-shrink: 0;
		}
		.social-links {
			display: none;
		}
	}
	@media (max-width: 430px) {
		header {
			padding-top: var(--safe-area-top);
			padding-left: max(1em, var(--safe-area-left));
			padding-right: max(1em, var(--safe-area-right));
		}
		nav a {
			padding: 0.85em 0.6em;
			min-height: 44px;
			display: inline-flex;
			align-items: center;
		}
		.header-actions {
			gap: 0.5rem;
		}
	}
</style>
