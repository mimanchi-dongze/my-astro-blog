---
const normalizedBaseUrl = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<site-search>
  <div id="search" class="search-container"></div>
</site-search>

<link href={`${normalizedBaseUrl}pagefind/pagefind-ui.css`} rel="stylesheet" />
<script is:inline src={`${normalizedBaseUrl}pagefind/pagefind-ui.js`}></script>

<script>
  class SiteSearch extends HTMLElement {
    connectedCallback() {
      const target = this.querySelector('#search');
      if (!target || target.dataset.initialized) return;
      target.dataset.initialized = "true";

      const init = () => {
        if (window.PagefindUI) {
          new window.PagefindUI({ element: "#search", showSubResults: true });
        } else {
          setTimeout(init, 50);
        }
      };
      
      init();
    }
  }

  if (!customElements.get('site-search')) {
    customElements.define('site-search', SiteSearch);
  }
</script>

<style is:global>
  .search-container {
    margin: 2rem 0;
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: rgb(var(--gray-light));
    --pagefind-ui-tag: rgb(var(--gray-light));
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: inherit;
  }

  /* Input styling */
  .search-container .pagefind-ui__search-input {
    font-weight: 400;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .search-container .pagefind-ui__search-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(35, 55, 255, 0.1);
  }

  .dark .search-container .pagefind-ui__search-input:focus {
    box-shadow: 0 0 0 3px rgba(107, 124, 255, 0.15);
  }

  .search-container .pagefind-ui__search-clear {
    background-color: transparent;
  }

  /* Result card styling */
  .search-container .pagefind-ui__result {
    border: 1px solid rgb(var(--gray-light));
    padding: 1.5rem;
    border-radius: var(--pagefind-ui-border-radius);
    margin-top: 1rem;
    margin-bottom: 1rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    background-color: var(--bg);
    box-shadow: 0 2px 4px rgba(var(--black), 0.03);
  }

  .search-container .pagefind-ui__result:hover {
    box-shadow: var(--box-shadow);
    transform: translateY(-2px);
  }

  .search-container .pagefind-ui__result-title {
    font-weight: 700;
    margin-top: 0;
  }

  .search-container .pagefind-ui__result-link {
    color: var(--accent);
    text-decoration: none;
  }

  .search-container .pagefind-ui__result-link:hover {
    text-decoration: underline;
  }

  .search-container .pagefind-ui__result-excerpt {
    color: var(--text);
    opacity: 0.9;
    margin-top: 0.5rem;
    line-height: 1.6;
  }

  /* Highlighted search terms */
  .search-container mark {
    background-color: rgba(35, 55, 255, 0.15);
    color: var(--text);
    padding: 0.1em 0.2em;
    border-radius: 3px;
    font-weight: 600;
  }

  .dark .search-container mark {
    background-color: rgba(107, 124, 255, 0.25);
  }

  /* Messages and buttons */
  .search-container .pagefind-ui__message {
    color: var(--text);
    opacity: 0.7;
    padding: 1rem 0;
  }

  .search-container .pagefind-ui__button {
    background-color: rgb(var(--gray-light));
    color: var(--text);
    border: none;
    font-weight: 600;
    transition: background-color 0.2s ease;
  }

  .search-container .pagefind-ui__button:hover {
    background-color: rgba(var(--gray), 0.2);
  }
</style>
