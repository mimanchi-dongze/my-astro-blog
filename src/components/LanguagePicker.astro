---
import { languages } from '../i18n/ui';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
---
<div class="lang-picker">
  <ul>
    {Object.entries(languages).map(([code, label]) => (
      <li>
        <a href={code === 'zh-cn' ? '/' : `/${code}/`} class={lang === code ? 'active' : ''}>
          {label}
        </a>
      </li>
    ))}
  </ul>
</div>
<style>
  .lang-picker ul { list-style: none; display: flex; gap: 0.5rem; padding: 0; margin: 0; }
  .lang-picker a { text-decoration: none; color: rgb(var(--gray)); font-size: 0.9em; }
  .lang-picker a.active { color: var(--accent); font-weight: bold; }
</style>
